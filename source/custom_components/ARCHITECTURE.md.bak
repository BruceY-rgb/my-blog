## 🔐 安全性

### 1. 输入验证
```javascript
// 验证用户输入
function setCity(city) {
  if (typeof city !== 'string' || city.length > 50) {
    throw new Error('无效的城市名称');
  }
  // 安全处理
  return city.replace(/[<>'"]/g, '');
}
```

### 2. XSS 防护
```javascript
// 使用 textContent 而非 innerHTML
element.textContent = userInput;

// 如果必须使用 innerHTML，进行转义
element.innerHTML = escapeHtml(userInput);
```

### 3. CSP 兼容
```javascript
// 避免内联事件和脚本
// 错误
element.onclick = () => {};

// 正确
element.addEventListener('click', () => {});
```

---

## 🚀 性能优化

### 1. 懒加载
```javascript
// IntersectionObserver 实现懒加载
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      initComponent(entry.target);
      observer.unobserve(entry.target);
    }
  });
});

document.querySelectorAll('.cc-component').forEach(el => {
  observer.observe(el);
});
```

### 2. 防抖
```javascript
// 搜索框防抖
function debounce(func, wait) {
  let timeout;
  return function executedFunction(...args) {
    const later = () => {
      clearTimeout(timeout);
      func(...args);
    };
    clearTimeout(timeout);
    timeout = setTimeout(later, wait);
  };
}
```

### 3. 缓存
```javascript
// 缓存 API 请求结果
const cache = new Map();

function fetchWeather(city) {
  if (cache.has(city)) {
    return cache.get(city);
  }

  const promise = fetch(`/api/weather/${city}`)
    .then(res => res.json());

  cache.set(city, promise);
  return promise;
}
```

